generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum SubtaskStatus {
  BACKLOG
  IN_PROGRESS
  REVIEW
  DONE
}

enum SubtaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  email               String               @unique
  password            String
  projects            Project[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Project {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  techStack   String[]
  repoUrl     String?
  status      ProjectStatus @default(PLANNING)
  ownerId     String        @db.ObjectId
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  subtasks    Subtask[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Subtask {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  status      SubtaskStatus   @default(BACKLOG)
  priority    SubtaskPriority @default(MEDIUM)
  dueDate     DateTime?
  projectId   String          @db.ObjectId
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updates     SubtaskUpdate[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model SubtaskUpdate {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  summary         String
  timeLogMinutes  Int
  loggedAt        DateTime  @default(now())
  subtaskId       String    @db.ObjectId
  subtask         Subtask   @relation(fields: [subtaskId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PasswordResetToken {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String
  codeHash     String
  expiresAt    DateTime
  expiresAtIst String?
  failedTries  Int      @default(0)
  verifiedAt   DateTime?
  consumedAt   DateTime?
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  createdAtIst String?
  updatedAt    DateTime @updatedAt
  updatedAtIst String?
}
